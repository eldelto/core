{{define "content"}} 

<script defer src='{{asset "main.js"}}'></script>

<form method="POST" action="{{.CurrentURL}}"
	  enctype="multipart/form-data">
  <input type="file" name="files"
		 multiple="true" id="files-input">
</form>

<template id="path-input">
  <input type="hidden" name="paths">
</template>
<form method="POST" action="/file/download" id="download-form">
</form>
<form method="POST" action="/file/delete" id="delete-form">
</form>

<table class="dir-list">
  <thead>
	<th></th>
	<th>name</th>
	<th>size</th>
	<th>last modified</th>
  </thead>
  <tbody>
	{{if ne .CurrentPath "."}}
	<tr>
	  <td></td>
	  <td>
		<span>dir</span>
		<a href="{{.ParentPath}}" id="parent">parent</a>
	  </td>
	  <td></td>
	  <td></td>
	</tr>
	{{end}}
	{{range .Entries}}
	<tr>
	  <td>
		<input type="checkbox" name="item">
		<input type="hidden" name="path" value="{{$.CurrentPath}}/{{.Name}}">
	  </td>
	  <td>
		{{if .IsDir}}
		<span>dir</span><a href="{{$.CurrentURL.JoinPath .Name}}">{{.Name}}</a>
		{{else}}
		<span>file</span><a href="{{$.CurrentURL.JoinPath .Name}}?preview=true">{{.Name}}</a>
		{{end}}
	  </td>
	  <td>{{.Size}}</td>
	  <td>{{.ModTime.String}}</td>
	</tr>
	{{end}}
  </tbody>
</table>

<dialog id="create-dir-dialog">
  <h3>Create directory:</h3>
  <form method="POST" action="/file/directory">
	<input type="text" name="path" value="{{.CurrentPath}}/">
	<button>Create</button>
  </form>

  <form method="dialog">
	<button>Cancel</button>
  </form>
</dialog>

{{end}}
